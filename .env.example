# --- LLM для агента, симулятора пользователя и судьи ---
# Провайдеры: fake | openai | deepseek | qwen | glm | moonshot | mistral | gemini | yandex | anthropic | gigachat
# Большинство — OpenAI-совместимы (base_url зашит). Любой другой такой вендор: openai + LLM_BASE_URL=<url>.
LLM_PROVIDER=fake
LLM_MODEL=gpt-5.5            # модель провайдера (yandex: gpt://<folder-id>/yandexgpt/latest)
LLM_API_KEY=                 # ключ (или <PROVIDER>_API_KEY в окружении, напр. DEEPSEEK_API_KEY). НЕ коммитить!
# LLM_BASE_URL=              # переопределить endpoint вручную (опционально)

# --- опционально: отдельный судья, ЛУЧШЕ другого вендора (чтобы не оценивал «сам себя») ---
# напр. агент openai/gpt-5.5, судья deepseek:
# LLM_JUDGE_PROVIDER=deepseek
# LLM_JUDGE_MODEL=deepseek-chat
# LLM_JUDGE_API_KEY=
# LLM_JUDGE_BASE_URL=

# --- GovTech 1.0 (baseline, классификаторы+зашитая логика) ---
GOV1_ENDPOINT=               # URL API старого GovTech
GOV1_TOKEN=

# --- GovTech 2.0 (A2A), подключить когда запустится ---
GOV2_A2A_ENDPOINT=
GOV2_TOKEN=
