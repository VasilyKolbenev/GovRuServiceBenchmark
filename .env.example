# --- LLM для симулированного пользователя, судьи и референс-агента ---
LLM_PROVIDER=fake            # fake | anthropic | openai
LLM_MODEL=gpt-5.5
LLM_API_KEY=                 # ключ провайдера (или задайте OPENAI_API_KEY в окружении). НЕ коммитить!

# --- опционально: отдельная модель судьи (чтобы судья не оценивал «сам себя») ---
# LLM_JUDGE_PROVIDER=openai
# LLM_JUDGE_MODEL=gpt-5.5
# LLM_JUDGE_API_KEY=

# --- GovTech 1.0 (baseline, классификаторы+зашитая логика) ---
GOV1_ENDPOINT=               # URL API старого GovTech
GOV1_TOKEN=

# --- GovTech 2.0 (A2A), подключить когда запустится ---
GOV2_A2A_ENDPOINT=
GOV2_TOKEN=
